# League Tokens Backend — Environment Configuration
# Copy this file to set up your environment. Never commit a .env file.
# Secrets are read from /run/secrets/<name> — see "Secret files" below.

# ── Postgres ──────────────────────────────────────────────────────────
PG_DATABASE=league_tokens
PG_USER=postgres
PG_HOST=localhost
PG_PORT=5432
PG_SSLMODE=disable
PG_MAX_CONNS=25

# ── HTTP ──────────────────────────────────────────────────────────────
HTTP_LISTEN_ADDR=:8080
HTTP_TRUSTED_PROXIES=

# ── Telemetry / Observability ─────────────────────────────────────────
OTLP_ENDPOINT=
SERVICE_NAME=league-tokens-backend
LOG_LEVEL=info

# ── Identity / Auth ───────────────────────────────────────────────────
SESSION_TTL=24h

# ── Schedule (game schedule provider) ─────────────────────────────────
SCHEDULE_PROVIDER_URL=
SCHEDULE_SYNC_INTERVAL=5m

# ── Feed (external data ingestion) ────────────────────────────────────
FEED_PROVIDER_URL=
FEED_POLL_INTERVAL=1m

# ── Game ──────────────────────────────────────────────────────────────
# (no env vars at Launch)

# ── Ledger ────────────────────────────────────────────────────────────
# (no env vars at Launch)

# ── Secret files (mounted at /run/secrets/<name> in Docker) ───────────
# pg_password       — Postgres password
# jwt_signing_key   — Ed25519 private key for JWT signing (PEM)
# provider_api_key  — API key for the external data provider
# otlp_token        — OTLP/gRPC authentication token (Grafana Cloud)
